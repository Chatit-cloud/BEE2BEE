# Bee2Bee Configuration Example
# Copy this to .env and fill in the values

# Port for the P2P Node (Worker/Main Point)
BEE2BEE_PORT=4003

# API Key for protecting the FastAPI endpoints
# If set, clients must include 'X-API-KEY: your_key_here' in headers
BEE2BEE_API_KEY=your_secure_random_key_here

# Main Point connection (Bootstrap)
# BEE2BEE_BOOTSTRAP=ws://your-main-point:4003

# Logging level (optional: DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
